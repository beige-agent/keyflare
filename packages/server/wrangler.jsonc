{
  "name": "keyflare",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-07",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true
    }
  },
  // D1 database binding
  "d1_databases": [
    {
      "binding": "DB_BINDING",
      "database_name": "keyflare",
      "migrations_dir": "migrations"
    }
  ],
  // Alias for bundled CLI package - resolves @keyflare/shared from sibling folder
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.ts"],
      "esbuild": {
        "alias": {
          "@keyflare/shared": "../shared/dist/index.js"
        }
      }
    }
  ]
}
